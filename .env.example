# Supabase — copy to .env.local and fill in from your Supabase project:
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Microsoft To Do (optional) — Azure app registration for read-only task access
# Entra admin center → App registrations → New; add redirect URI:
#   http://localhost:3000/api/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# "consumers" for personal Microsoft accounts, "common" for both
MICROSOFT_TENANT=consumers
